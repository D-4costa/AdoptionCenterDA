@page "/cats"

<PageTitle>Cats | Adoption Center</PageTitle>

<div class="page-container">

    <SectionTitle
        Title="Cats Looking for a Loving Home 🐱"
        Subtitle="Meet our adorable cats waiting for a caring family." />

    <div class="results-summary">

        <span class="results-badge">

            @Cats.Count cat(s) available for adoption

        </span>

    </div>

    @if (Cats.Any())
    {
        <div class="pet-grid">

            @foreach (var cat in Cats)
            {
                <PetCard Pet="cat" />
            }

        </div>
    }
    else
    {
        <div class="empty-state">

            <h3>No cats available right now.</h3>

            <p>
                Please check back later. New pets arrive frequently!
            </p>

        </div>
    }

</div>
