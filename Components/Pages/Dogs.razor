@page "/dogs"

<PageTitle>Dogs | Adoption Center</PageTitle>

<div class="page-container">

    <SectionTitle
        Title="Dogs Looking for a Loving Home 🐶"
        Subtitle="Meet our friendly dogs waiting for a caring family." />

    <div class="results-summary">

        <span class="results-badge">

            @Dogs.Count dog(s) available for adoption

        </span>

    </div>

    @if (Dogs.Any())
    {
        <div class="pet-grid">

            @foreach (var dog in Dogs)
            {
                <PetCard Pet="dog" />
            }

        </div>
    }
    else
    {
        <div class="empty-state">

            <h3>No dogs available right now.</h3>

            <p>
                Please check back later. New pets arrive frequently!
            </p>

        </div>
    }

</div>
