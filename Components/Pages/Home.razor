@page "/"

<PageTitle>Adoption Center</PageTitle>

<HeroBanner />

<section class="featured-section">

    <SectionTitle
        Title="Featured Pets"
        Subtitle="Meet some of our adorable pets currently looking for a loving home." />

    <div class="pet-grid">

        @foreach (var pet in FeaturedPets)
        {
            <PetCard Pet="pet" />
        }

    </div>

</section>

<section class="why-adopt-section">

    <SectionTitle
        Title="Why Adopt?"
        Subtitle="Adopting a pet changes lives, including your own." />

    <div class="info-grid">

        <div class="info-card">

            <div class="info-icon">
                ❤️
            </div>

            <h3>
                Save a Life
            </h3>

            <p>
                Every adoption gives a pet the opportunity to start a new chapter
                with a caring family.
            </p>

        </div>

        <div class="info-card">

            <div class="info-icon">
                🏡
            </div>

            <h3>
                Find a Best Friend
            </h3>

            <p>
                Pets provide companionship, loyalty, and unconditional love for
                many years.
            </p>

        </div>

        <div class="info-card">

            <div class="info-icon">
                🌎
            </div>

            <h3>
                Make a Difference
            </h3>

            <p>
                By adopting instead of shopping, you help reduce the number of
                homeless animals.
            </p>

        </div>

    </div>

</section>

    }

}
